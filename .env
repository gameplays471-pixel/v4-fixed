# Supabase PostgreSQL - URLs para Vercel + dev local
#
# DATABASE_URL: pooler transacional (porta 6543 com pgbouncer=true)
#   - Necessário para Vercel serverless (funções efêmeras precisam de pool)
#   - Funciona para dev local também
#
# DIRECT_URL: pooler sessão (porta 5432, sem pgbouncer)
#   - Usado pelo Prisma para migrations (db push, migrate)
#   - Não pode ter pgbouncer=true em migrations
DATABASE_URL=postgresql://postgres.coyaqzvmpcdhxwtoowye:WLTM4q9FIquG1ItF@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.coyaqzvmpcdhxwtoowye:WLTM4q9FIquG1ItF@aws-1-us-west-2.pooler.supabase.com:5432/postgres
